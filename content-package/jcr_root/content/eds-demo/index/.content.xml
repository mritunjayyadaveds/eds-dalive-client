          <item_3 jcr:primaryType="nt:unstructured" sling:resourceType="core/franklin/components/block/v1/block/item" name="Tab" model="tab-item" modelFields="[image,imageAlt,text]" image="/content/dam/eds-demo/kent-state-university.jpg" imageAlt="Kent State University" text="&lt;p&gt;&lt;strong&gt;Institutional Investors&lt;/strong&gt;&lt;/p&gt;&lt;h3&gt;Kent State University&lt;/h3&gt;&lt;p&gt;Kent State University partnered with SEI to modernize its endowment and foundation investment management — gaining access to institutional-quality strategies and operational support.&lt;/p&gt;&lt;p&gt;&lt;a href=&quot;#&quot;&gt;Read the full case study →&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;$400M+&lt;/strong&gt; Endowment and foundation assets managed on SEI platform&lt;/p&gt;&lt;p&gt;&lt;strong&gt;OCIO&lt;/strong&gt; Outsourced chief investment officer model for governance efficiency&lt;/p&gt;"/>
